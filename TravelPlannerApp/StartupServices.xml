<?xml version="1.0" encoding="utf-8"?>
<StartupServicesManifest xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://schemas.microsoft.com/2011/01/fabric">
  <Parameters>
    <Parameter Name="EmailService_MinReplicaSetSize" DefaultValue="3" />
    <Parameter Name="EmailService_PartitionCount" DefaultValue="1" />
    <Parameter Name="EmailService_TargetReplicaSetSize" DefaultValue="3" />
    <Parameter Name="TripService_InstanceCount" DefaultValue="-1" />
    <Parameter Name="UserService_InstanceCount" DefaultValue="-1" />
    <Parameter Name="TripPlanerAPI_InstanceCount" DefaultValue="-1" />
  </Parameters>
  <Services>
    <Service Name="EmailService" ServicePackageActivationMode="ExclusiveProcess">
      <StatefulService ServiceTypeName="EmailServiceType" TargetReplicaSetSize="[EmailService_TargetReplicaSetSize]" MinReplicaSetSize="[EmailService_MinReplicaSetSize]">
        <UniformInt64Partition PartitionCount="[EmailService_PartitionCount]" LowKey="-9223372036854775808" HighKey="9223372036854775807" />
      </StatefulService>
    </Service>
    <Service Name="TripService" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="TripServiceType" InstanceCount="[TripService_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
    <Service Name="UserService" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="UserServiceType" InstanceCount="[UserService_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
    <Service Name="TripPlanerAPI" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="TripPlanerAPIType" InstanceCount="[TripPlanerAPI_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
  </Services>
</StartupServicesManifest>